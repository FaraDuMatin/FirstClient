# Copy to .env.local and fill in. Everything degrades gracefully when missing:
# no MONGODB_URI -> in-memory store, no GEMINI_API_KEY -> analysis routes 503,
# no ELEVENLABS_* -> voice routes 503. `npm run dev` works with zero keys.

# ElevenLabs Agents (voice client persona)
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# Gemini API (submission vision analysis + evaluation) — free tier
GEMINI_API_KEY=

# MongoDB Atlas (free tier). Leave empty for in-memory dev store.
MONGODB_URI=
